# --- ENV & AUTH (Managed via .env only) ---

# Environment mode: development or production
# This variable is accessed directly by main.rs to set log levels.
# It is NOT present in any YAML file.
OAPI_ENV=development

# Database connection
PB_EMAIL=
PB_PASSWORD=
PB_URL=

# --- LOGGING ---
# Logging level (standard tracing-subscriber filter)
# Example: RUST_LOG=info,OAPI=debug
RUST_LOG=info,OAPI=debug,tower_http=debug
